# Firebase Admin SDK (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# JWT secrets — generate with: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Public app URL (used for cookies, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Authentication
# development = OTP bypass (any 6-digit code accepted); production = strict OTP match
AUTH_MODE=development
# Explicit override — takes precedence over AUTH_MODE when set
# OTP_BYPASS=true

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Firebase Storage (optional — defaults to {FIREBASE_PROJECT_ID}.appspot.com)
# FIREBASE_STORAGE_BUCKET=

# Payment integrations (optional — stubs used until configured)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
